# Exclude everything
**

# But not .php files or html files
!*.php
!**/*.php

# Vite manifest (Laravel resolves asset URLs from it server-side)
!public/build/manifest.json

# These often exist in empty dirs that must be deployed
!**/.gitignore

!.env.empty
!*.ini

# And not vendor directories
!**/vendor/
!**/vendor/**/*
