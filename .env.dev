# Local development template — copied to .env by `make env`.
#
# APP_KEY is intentionally a fixed plain 32-char string (NOT base64:):
# the legacy site decrypts our session cookie with the same key
# (website_root .env REDIS_KEY). Do not run key:generate — it would
# break the login -> MyCurriculum session handoff.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=e2elocalsharedkey123456789abcdef
APP_DEBUG=true
APP_URL=http://localhost:8090
APP_PORT=8090

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=apex_login
DB_USERNAME=sail
DB_PASSWORD=password
FORWARD_DB_PORT=3310

BROADCAST_DRIVER=log
CACHE_DRIVER=file
CACHE_PREFIX=laravel
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync

# Sessions live in shared Redis so the legacy site can read them
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_COOKIE=ApexInnovations
SESSION_DOMAIN=null

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
FORWARD_MAILHOG_PORT=11025
FORWARD_MAILHOG_DASHBOARD_PORT=18025

# Local website_root container (legacy main site)
WEBSITE_PORT=8091
MYCURRICULUM_URL=http://localhost:8091/MyCurriculum.php

WWWUSER=1000
WWWGROUP=1000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
